# Smart Campus Security System — Environment Variables
# Copy this to .env and fill in your values

# Security — CHANGE THIS in production (use a long random string)
SECRET_KEY=your-super-secret-key-change-this-before-deploying

# Token expiry in minutes (default: 1440 = 24 hours)
TOKEN_EXPIRE_MINUTES=1440

# Database (leave as default for SQLite, or use postgresql://user:pass@host/db)
DATABASE_URL=sqlite:///./smart_campus.db

# Server port (used by Render/Railway via $PORT)
PORT=8000
